{
  "name": "agent-lens",
  "version": "0.0.0",
  "private": true,
  "description": "Local-only tool that passively collects, browses, and analyzes Claude Code CLI session traces.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r build && vitest run",
    "collect": "pnpm --filter agent-lens build && node packages/cli/dist/agent-lens.js collect",
    "ingest": "pnpm --filter @agent-lens/ingest start",
    "serve": "pnpm --filter @agent-lens/server start",
    "web:dev": "pnpm --filter @agent-lens/web dev",
    "validate": "node scripts/validate.mjs",
    "build-corpus": "scripts/build-corpus.sh",
    "sandbox": "scripts/sandbox.sh"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^24.0.0",
    "playwright": "1.61.1",
    "semantic-release": "^25.0.5",
    "sharp": "^0.35.3",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
