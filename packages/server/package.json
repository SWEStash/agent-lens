{
  "name": "@agent-lens/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/run.js",
  "exports": {
    ".": {
      "types": "./dist/run.d.ts",
      "default": "./dist/run.js"
    }
  },
  "bin": {
    "agent-lens-server": "./dist/index.js"
  },
