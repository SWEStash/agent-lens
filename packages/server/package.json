  },
  "dependencies": {
    "@agent-lens/core": "workspace:*",
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11"
  }
}
