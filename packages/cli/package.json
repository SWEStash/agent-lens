{
  "name": "@swestash/agent-lens",
  "version": "0.4.0",
  "type": "module",
  "description": "Local-only tool that passively collects, browses, and analyzes Claude Code CLI session traces.",
  "license": "MIT",
  "author": "SWEStash",
  "homepage": "https://github.com/SWEStash/agent-lens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SWEStash/agent-lens.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/SWEStash/agent-lens/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "agent",
    "traces",
    "session",
    "observability",
    "analytics",
    "cli",
    "local-first",
    "privacy"
  ],
  "bin": {
    "agent-lens": "./dist/agent-lens.js"
  },
  "files": [
    "dist",
    "web",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-web.mjs",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^4.0.3",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@agent-lens/core": "workspace:*",
    "@agent-lens/ingest": "workspace:*",
    "@agent-lens/server": "workspace:*",
    "@agent-lens/web": "workspace:*",
    "cac": "^6.7.14",
    "tsup": "^8.5.0"
  }
}
