# Planning artifacts (ADRs, plans) — local-only, never committed.
.local/

# Collected runtime data (archive + SQLite store) — keep the folder, ignore contents.
/data/*
!/data/.gitkeep

# Real sources config (machine-specific); ship only the example.
/agent-lens.config.json

# Node
node_modules/
dist/
*.tsbuildinfo
.pnpm-store/

# Generated, corpus-only API snapshot for the static (GitHub Pages) build — rebuilt by
# scripts/export-snapshot.mjs in CI; never hand-edited or committed.
/packages/web/public/snapshot/

# Databases / data artifacts
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Secrets / env
.env
.env.*
*.credentials.json

# OS / editor
.DS_Store
*.log
.idea/
.vscode/
